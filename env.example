# ============================================================
# .env.example — Fleur & Atelier
# ============================================================
# Copie ce fichier en .env et remplis les valeurs.
# Ne jamais committer le fichier .env dans git.
# Ajoute .env dans ton .gitignore.
# ============================================================


# ============================================================
# BACKEND — Spring Boot (application.properties)
# ============================================================
# Copie les valeurs ci-dessous dans src/main/resources/application.properties

# --- Base de données PostgreSQL ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fleur_atelier_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=ton_mot_de_passe_ici

# --- JPA / Hibernate ---
# Options : create | create-drop | update | validate | none
# Utilise "update" en développement, "validate" en production
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# --- JWT ---
# Génère une clé secrète longue et aléatoire (min 256 bits pour HS256)
# Exemple : openssl rand -base64 64
JWT_SECRET=remplace_par_une_cle_secrete_tres_longue_et_aleatoire_minimum_64_caracteres
# Durée de validité du token en millisecondes (86400000 = 24 heures)
JWT_EXPIRATION=86400000

# --- Serveur Spring Boot ---
SERVER_PORT=8080

# --- Logs ---
LOGGING_LEVEL_COM_FLEURATELIER=DEBUG
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG


# ============================================================
# BACKEND — application.properties (copie tel quel)
# ============================================================
# Crée le fichier src/main/resources/application.properties
# avec ce contenu (remplace les ${VAR} par tes vraies valeurs) :
#
# spring.datasource.url=jdbc:postgresql://localhost:5432/fleur_atelier_db
# spring.datasource.username=postgres
# spring.datasource.password=ton_mot_de_passe_ici
# spring.datasource.driver-class-name=org.postgresql.Driver
#
# spring.jpa.hibernate.ddl-auto=update
# spring.jpa.show-sql=true
# spring.jpa.properties.hibernate.format_sql=true
# spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
# spring.jpa.open-in-view=false
#
# jwt.secret=remplace_par_une_cle_secrete_tres_longue_et_aleatoire_minimum_64_caracteres
# jwt.expiration=86400000
#
# server.port=8080
#
# logging.level.com.fleuratelier=DEBUG
# logging.level.org.hibernate.SQL=DEBUG
# logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE


# ============================================================
# FRONTEND — React + Vite (.env dans le dossier fleur-atelier-ui/)
# ============================================================
# Crée le fichier fleur-atelier-ui/.env avec ce contenu :

# URL de l'API Spring Boot
# Vite expose uniquement les variables préfixées VITE_
VITE_API_BASE_URL=http://localhost:8080/api

# Nom de l'app (utilisé dans le title HTML et les meta)
VITE_APP_NAME=Fleur & Atelier

# Mode (development | production)
VITE_APP_ENV=development


# ============================================================
# BASE DE DONNÉES — Commandes PostgreSQL utiles
# ============================================================
# Créer la base de données (à exécuter une seule fois) :
#   psql -U postgres -c "CREATE DATABASE fleur_atelier_db;"
#
# Se connecter à la base :
#   psql -U postgres -d fleur_atelier_db
#
# Voir les tables créées par Hibernate :
#   \dt
#
# Réinitialiser complètement la base (développement) :
#   psql -U postgres -c "DROP DATABASE fleur_atelier_db;"
#   psql -U postgres -c "CREATE DATABASE fleur_atelier_db;"
#   Puis redémarrer Spring Boot


# ============================================================
# DOCKER (optionnel — pour PostgreSQL en local sans installation)
# ============================================================
# Si tu préfères lancer PostgreSQL via Docker :
#
# docker run --name fleur-atelier-db \
#   -e POSTGRES_DB=fleur_atelier_db \
#   -e POSTGRES_USER=postgres \
#   -e POSTGRES_PASSWORD=ton_mot_de_passe_ici \
#   -p 5432:5432 \
#   -d postgres:15
#
# Pour pgAdmin (interface graphique) :
# docker run --name pgadmin \
#   -e PGADMIN_DEFAULT_EMAIL=admin@admin.com \
#   -e PGADMIN_DEFAULT_PASSWORD=admin \
#   -p 5050:80 \
#   -d dpage/pgadmin4


# ============================================================
# .gitignore — Ajoute ces lignes dans ton .gitignore
# ============================================================
# .env
# .env.local
# .env.production
# src/main/resources/application-prod.properties
# *.jar
# target/
# node_modules/
# dist/
# .vite/
